# CryptoSparrow VPS env template (docker-compose.vps.yml)
#
# This file is intentionally not production-ready as-is. Replace all
# CHANGEME_* values with high-entropy secrets before deployment; the API
# readiness check rejects placeholder values.

NODE_ENV=production

# Public URLs (adjust to your HTTPS domain/reverse proxy)
SERVER_URL=https://api.soar.example.com
CLIENT_URL=https://soar.example.com
CORS_ORIGINS=https://soar.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.soar.example.com

# API auth / encryption (replace before production use)
JWT_SECRET=CHANGEME_GENERATE_64_RANDOM_CHARS
# Optional shared cookie domain for web + api subdomains
# Example: .soar.luckysparrow.ch
# COOKIE_DOMAIN=
API_KEY_ENCRYPTION_KEYS=v1:CHANGEME_GENERATE_32_PLUS_RANDOM_CHARS
API_KEY_ENCRYPTION_ACTIVE_VERSION=v1

# Data stores
# If using compose --profile infra, replace passwords below first.
# If using managed DB/Redis, replace with external URLs.
POSTGRES_PASSWORD=CHANGEME_GENERATE_POSTGRES_PASSWORD
REDIS_PASSWORD=CHANGEME_GENERATE_REDIS_PASSWORD
DATABASE_URL=postgresql://postgres:CHANGEME_GENERATE_POSTGRES_PASSWORD@postgres:5432/cryptosparrow?schema=public
REDIS_URL=redis://:CHANGEME_GENERATE_REDIS_PASSWORD@redis:6379

# Optional tuning
SERVER_PORT=3001

# Coin icon resolver (CoinGecko + fallback)
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
# Recommended on VPS stage/prod to reduce rate limits
# COINGECKO_API_KEY=
COIN_ICON_CACHE_TTL_MINUTES=360
