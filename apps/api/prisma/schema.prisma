// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())

  email          String  @unique
  password       String
  sessionVersion Int     @default(1)
  name           String?
  avatarUrl      String?
  role           Role    @default(USER)
  uiPreferences  Json?

  apiKeys                  ApiKey[]
  strategies               Strategy[]
  marketUniverses          MarketUniverse[]
  symbolGroups             SymbolGroup[]
  bots                     Bot[]
  botMarketGroups          BotMarketGroup[]
  marketGroupStrategyLinks MarketGroupStrategyLink[]
  botAssistantConfigs      BotAssistantConfig[]
  botSubagentConfigs       BotSubagentConfig[]
  botRuntimeSessions       BotRuntimeSession[]
  botRuntimeEvents         BotRuntimeEvent[]
  botRuntimeSymbolStats    BotRuntimeSymbolStat[]
  runtimeExecutionDedupes  RuntimeExecutionDedupe[]
  positions                Position[]
  orders                   Order[]
  trades                   Trade[]
  orderFills               OrderFill[]
  signals                  Signal[]
  backtestRuns             BacktestRun[]
  backtestTrades           BacktestTrade[]
  backtestReports          BacktestReport[]
  subscriptionAssignments  UserSubscription[]
  paymentIntents           PaymentIntent[]
  wallets                  Wallet[]
  walletBalanceSnapshots   WalletBalanceSnapshot[]
  walletCashflowEvents     WalletCashflowEvent[]
  logs                     Log[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionPlanCode {
  FREE
  ADVANCED
  PROFESSIONAL
}

enum UserSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum UserSubscriptionSource {
  DEFAULT
  ADMIN_OVERRIDE
  CHECKOUT
}

enum PaymentProvider {
  STRIPE
  KLARNA
  MANUAL
  OTHER
}

enum PaymentIntentStatus {
  CREATED
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  CANCELED
  FAILED
  EXPIRED
}

model SubscriptionPlan {
  id String @id @default(uuid())

  code        SubscriptionPlanCode @unique
  slug        String               @unique
  displayName String
  isActive    Boolean              @default(true)
  sortOrder   Int                  @default(0)

  monthlyPriceMinor Int
  currency          String @default("USD")
  entitlements      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions  UserSubscription[]
  paymentIntents PaymentIntent[]

  @@index([isActive, sortOrder])
}

model UserSubscription {
  id String @id @default(uuid())

  userId             String
  subscriptionPlanId String

  status    UserSubscriptionStatus @default(ACTIVE)
  source    UserSubscriptionSource @default(DEFAULT)
  autoRenew Boolean                @default(true)
  startsAt  DateTime               @default(now())
  endsAt    DateTime?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  paymentIntents   PaymentIntent[]

  @@index([userId])
  @@index([userId, status])
  @@index([subscriptionPlanId, status])
  @@index([startsAt, endsAt])
}

model PaymentIntent {
  id String @id @default(uuid())

  userId             String
  subscriptionPlanId String
  userSubscriptionId String?

  provider          PaymentProvider
  status            PaymentIntentStatus @default(CREATED)
  providerReference String?
  idempotencyKey    String?

  amountMinor Int
  currency    String
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan  @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  userSubscription UserSubscription? @relation(fields: [userSubscriptionId], references: [id], onDelete: SetNull)

  @@unique([provider, providerReference])
  @@unique([idempotencyKey])
  @@index([userId, status])
  @@index([subscriptionPlanId, status])
  @@index([status, createdAt])
}

model ApiKey {
  id     String @id @default(uuid())
  userId String

  label                   String
  exchange                Exchange @default(BINANCE)
  apiKey                  String
  apiSecret               String
  syncExternalPositions   Boolean  @default(true)
  manageExternalPositions Boolean  @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastUsed  DateTime?
  user      User      @relation(fields: [userId], references: [id])
  bots      Bot[]
  wallets   Wallet[]
}

enum Exchange {
  BINANCE
  BYBIT
  OKX
  KRAKEN
  COINBASE
  GATEIO
}

model Strategy {
  id     String @id @default(uuid())
  userId String

  name        String
  description String?
  interval    String
  leverage    Int
  walletRisk  Float
  config      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                     User                      @relation(fields: [userId], references: [id])
  primaryBots              Bot[]                     @relation("BotPrimaryStrategy")
  botStrategies            BotStrategy[]
  marketGroupStrategyLinks MarketGroupStrategyLink[]
  positions                Position[]
  orders                   Order[]
  trades                   Trade[]
  orderFills               OrderFill[]
  signals                  Signal[]
  backtestRuns             BacktestRun[]
  backtestTrades           BacktestTrade[]
  logs                     Log[]
}

model MarketUniverse {
  id     String @id @default(uuid())
  userId String

  name             String
  exchange         Exchange    @default(BINANCE)
  marketType       TradeMarket @default(FUTURES)
  baseCurrency     String      @default("USDT")
  filterRules      Json?
  whitelist        String[]    @default([])
  blacklist        String[]    @default([])
  autoExcludeRules Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  symbolGroups SymbolGroup[]

  @@index([userId])
  @@index([userId, exchange, marketType, baseCurrency])
}

model SymbolGroup {
  id               String @id @default(uuid())
  userId           String
  marketUniverseId String

  name    String
  symbols String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  marketUniverse  MarketUniverse   @relation(fields: [marketUniverseId], references: [id])
  primaryBots     Bot[]            @relation("BotPrimarySymbolGroup")
  botStrategies   BotStrategy[]
  botMarketGroups BotMarketGroup[]

  @@index([userId])
  @@index([marketUniverseId])
}

model MarketCandleCache {
  id         String      @id @default(uuid())
  marketType TradeMarket
  symbol     String
  timeframe  String
  openTime   BigInt
  closeTime  BigInt
  open       Float
  high       Float
  low        Float
  close      Float
  volume     Float
  source     String      @default("BINANCE")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([marketType, symbol, timeframe, openTime])
  @@index([marketType, symbol, timeframe, openTime])
  @@index([marketType, symbol, timeframe, closeTime])
}

model Bot {
  id     String @id @default(uuid())
  userId String

  name               String
  strategyId         String?
  symbolGroupId      String?
  mode               BotMode      @default(PAPER)
  paperStartBalance  Float        @default(10000)
  exchange           Exchange     @default(BINANCE)
  marketType         TradeMarket  @default(FUTURES)
  positionMode       PositionMode @default(ONE_WAY)
  isActive           Boolean      @default(false)
  liveOptIn          Boolean      @default(false)
  manageExternalPositions Boolean @default(false)
  consentTextVersion String?
  maxOpenPositions   Int          @default(1)
  apiKeyId           String?
  walletId           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                     User                      @relation(fields: [userId], references: [id])
  apiKey                   ApiKey?                   @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  wallet                   Wallet?                   @relation(fields: [walletId], references: [id], onDelete: SetNull)
  strategy                 Strategy?                 @relation("BotPrimaryStrategy", fields: [strategyId], references: [id], onDelete: SetNull)
  symbolGroup              SymbolGroup?              @relation("BotPrimarySymbolGroup", fields: [symbolGroupId], references: [id], onDelete: SetNull)
  botStrategies            BotStrategy[]
  botMarketGroups          BotMarketGroup[]
  marketGroupStrategyLinks MarketGroupStrategyLink[]
  assistantConfig          BotAssistantConfig?
  subagentConfigs          BotSubagentConfig[]
  runtimeSessions          BotRuntimeSession[]
  runtimeEvents            BotRuntimeEvent[]
  runtimeSymbolStats       BotRuntimeSymbolStat[]
  runtimeExecutionDedupes  RuntimeExecutionDedupe[]
  positions                Position[]
  orders                   Order[]
  trades                   Trade[]
  orderFills               OrderFill[]
  signals                  Signal[]
  logs                     Log[]

  @@index([userId])
  @@index([apiKeyId])
  @@index([walletId])
  @@index([strategyId])
  @@index([symbolGroupId])
  @@index([userId, exchange])
}

enum TradeMarket {
  FUTURES
  SPOT
}

enum PositionMode {
  ONE_WAY
  HEDGE
}

model BotStrategy {
  id            String @id @default(uuid())
  botId         String
  strategyId    String
  symbolGroupId String

  isEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bot         Bot         @relation(fields: [botId], references: [id])
  strategy    Strategy    @relation(fields: [strategyId], references: [id])
  symbolGroup SymbolGroup @relation(fields: [symbolGroupId], references: [id])

  @@unique([botId, strategyId, symbolGroupId])
  @@index([botId])
  @@index([strategyId])
  @@index([symbolGroupId])
}

model BotMarketGroup {
  id            String @id @default(uuid())
  userId        String
  botId         String
  symbolGroupId String

  lifecycleStatus  BotMarketGroupStatus @default(ACTIVE)
  executionOrder   Int                  @default(100)
  maxOpenPositions Int                  @default(1)
  isEnabled        Boolean              @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                      @relation(fields: [userId], references: [id])
  bot           Bot                       @relation(fields: [botId], references: [id])
  symbolGroup   SymbolGroup               @relation(fields: [symbolGroupId], references: [id])
  strategyLinks MarketGroupStrategyLink[]

  /// BOTMULTI-03: PostgreSQL partial unique index
  /// BotMarketGroup_one_active_scope_per_bot_idx enforces at most one enabled
  /// ACTIVE market scope per bot. Prisma cannot express partial indexes in the
  /// schema DSL, so the invariant is owned by the manual migration.
  @@unique([botId, symbolGroupId])
  @@index([userId])
  @@index([botId])
  @@index([symbolGroupId])
  @@index([botId, lifecycleStatus, executionOrder])
}

enum BotMarketGroupStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

model MarketGroupStrategyLink {
  id               String @id @default(uuid())
  userId           String
  botId            String
  botMarketGroupId String
  strategyId       String

  priority  Int     @default(100)
  weight    Float   @default(1)
  isEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id])
  bot            Bot            @relation(fields: [botId], references: [id])
  botMarketGroup BotMarketGroup @relation(fields: [botMarketGroupId], references: [id])
  strategy       Strategy       @relation(fields: [strategyId], references: [id])

  @@unique([botMarketGroupId, strategyId])
  @@index([userId])
  @@index([botId])
  @@index([botMarketGroupId])
  @@index([strategyId])
  @@index([botMarketGroupId, isEnabled, priority])
}

model BotAssistantConfig {
  id     String @id @default(uuid())
  userId String
  botId  String @unique

  mainAgentEnabled     Boolean             @default(false)
  mandate              String?
  modelProfile         String              @default("balanced")
  safetyMode           AssistantSafetyMode @default(STRICT)
  maxDecisionLatencyMs Int                 @default(2500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  bot  Bot  @relation(fields: [botId], references: [id])

  @@index([userId])
  @@index([botId, mainAgentEnabled])
}

enum AssistantSafetyMode {
  STRICT
  BALANCED
  EXPERIMENTAL
}

model BotSubagentConfig {
  id        String @id @default(uuid())
  userId    String
  botId     String
  slotIndex Int

  role         String
  enabled      Boolean             @default(false)
  modelProfile String              @default("balanced")
  timeoutMs    Int                 @default(1200)
  safetyMode   AssistantSafetyMode @default(STRICT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  bot  Bot  @relation(fields: [botId], references: [id])

  @@unique([botId, slotIndex])
  @@index([userId])
  @@index([botId, enabled, slotIndex])
}

model BotRuntimeSession {
  id     String @id @default(uuid())
  userId String
  botId  String

  mode            BotMode
  status          BotRuntimeSessionStatus @default(RUNNING)
  startedAt       DateTime                @default(now())
  finishedAt      DateTime?
  lastHeartbeatAt DateTime?
  stopReason      String?
  errorMessage    String?
  metadata        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                   @relation(fields: [userId], references: [id])
  bot         Bot                    @relation(fields: [botId], references: [id])
  events      BotRuntimeEvent[]
  symbolStats BotRuntimeSymbolStat[]

  @@index([userId])
  @@index([botId])
  @@index([userId, botId, startedAt])
  @@index([botId, status, startedAt])
  @@index([status, startedAt])
}

enum BotRuntimeSessionStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

model BotRuntimeEvent {
  id        String @id @default(uuid())
  userId    String
  botId     String
  sessionId String

  eventType        BotRuntimeEventType
  level            BotRuntimeEventLevel @default(INFO)
  symbol           String?
  botMarketGroupId String?
  strategyId       String?
  signalDirection  SignalDirection?
  message          String?
  payload          Json?
  eventAt          DateTime             @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id])
  bot     Bot               @relation(fields: [botId], references: [id])
  session BotRuntimeSession @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([botId])
  @@index([sessionId])
  @@index([sessionId, eventAt])
  @@index([botId, eventAt])
  @@index([eventType, eventAt])
  @@index([symbol, eventAt])
}

enum BotRuntimeEventType {
  SESSION_STARTED
  SESSION_STOPPED
  HEARTBEAT
  SIGNAL_DECISION
  PRETRADE_BLOCKED
  ORDER_SUBMITTED
  ORDER_FILLED
  POSITION_OPENED
  POSITION_CLOSED
  DCA_EXECUTED
  ERROR
}

enum BotRuntimeEventLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model BotRuntimeSymbolStat {
  id        String @id @default(uuid())
  userId    String
  botId     String
  sessionId String

  symbol            String
  totalSignals      Int       @default(0)
  longEntries       Int       @default(0)
  shortEntries      Int       @default(0)
  exits             Int       @default(0)
  dcaCount          Int       @default(0)
  closedTrades      Int       @default(0)
  winningTrades     Int       @default(0)
  losingTrades      Int       @default(0)
  realizedPnl       Float     @default(0)
  grossProfit       Float     @default(0)
  grossLoss         Float     @default(0)
  feesPaid          Float     @default(0)
  openPositionCount Int       @default(0)
  openPositionQty   Float     @default(0)
  lastPrice         Float?
  lastSignalAt      DateTime?
  lastTradeAt       DateTime?
  snapshotAt        DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id])
  bot     Bot               @relation(fields: [botId], references: [id])
  session BotRuntimeSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, symbol])
  @@index([userId])
  @@index([botId])
  @@index([sessionId])
  @@index([botId, symbol])
  @@index([userId, botId, sessionId])
  @@index([sessionId, realizedPnl])
  @@index([sessionId, closedTrades])
}

model RuntimeExecutionDedupe {
  id String @id @default(uuid())

  dedupeKey          String                       @unique
  dedupeVersion      String
  commandType        RuntimeExecutionCommandType
  userId             String
  botId              String?
  symbol             String?
  status             RuntimeExecutionDedupeStatus @default(PENDING)
  commandFingerprint Json
  firstSeenAt        DateTime                     @default(now())
  lastSeenAt         DateTime                     @default(now())
  ttlExpiresAt       DateTime
  orderId            String?
  positionId         String?
  errorClass         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  bot  Bot? @relation(fields: [botId], references: [id], onDelete: SetNull)

  @@index([userId, commandType, status])
  @@index([botId])
  @@index([ttlExpiresAt])
  @@index([status, lastSeenAt])
}

enum RuntimeExecutionCommandType {
  OPEN
  DCA
  CLOSE
  CANCEL
}

enum RuntimeExecutionDedupeStatus {
  PENDING
  SUCCEEDED
  FAILED
  EXPIRED
}

enum BotMode {
  PAPER
  LIVE
}

enum WalletAllocationMode {
  PERCENT
  FIXED
}

enum WalletBalanceSnapshotSource {
  EXCHANGE_BALANCE
  MANUAL_REPAIR
}

enum WalletCashflowDirection {
  IN
  OUT
  NEUTRAL
}

enum WalletCashflowSource {
  INITIAL_BALANCE
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  BOT_REALIZED_PNL
  BOT_OPEN_PNL_SNAPSHOT
  FEE
  FUNDING
  UNKNOWN_EXTERNAL_ADJUSTMENT
}

model Wallet {
  id     String @id @default(uuid())
  userId String

  name               String
  mode               BotMode
  exchange           Exchange    @default(BINANCE)
  marketType         TradeMarket @default(FUTURES)
  baseCurrency       String      @default("USDT")
  paperInitialBalance Float      @default(10000)
  paperResetAt       DateTime?
  liveAllocationMode WalletAllocationMode?
  liveAllocationValue Float?
  apiKeyId           String?
  manageExternalPositions Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey    ApiKey?   @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  bots      Bot[]
  positions Position[]
  orders    Order[]
  trades    Trade[]
  balanceSnapshots WalletBalanceSnapshot[]
  cashflowEvents   WalletCashflowEvent[]

  @@index([userId])
  @@index([apiKeyId])
  @@index([userId, exchange, marketType, baseCurrency])
}

model WalletBalanceSnapshot {
  id       String @id @default(uuid())
  userId   String
  walletId String

  exchange     Exchange
  marketType   TradeMarket
  baseCurrency String

  accountBalance   Float
  freeBalance      Float
  allocatedBalance Float
  allocationMode   WalletAllocationMode?
  allocationValue  Float?

  fetchedAt   DateTime
  source      WalletBalanceSnapshotSource @default(EXCHANGE_BALANCE)
  externalRef String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet         Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  cashflowEvents WalletCashflowEvent[]

  @@index([userId])
  @@index([walletId, fetchedAt])
  @@index([userId, walletId, fetchedAt])
  @@index([exchange, marketType, baseCurrency, fetchedAt])
}

model WalletCashflowEvent {
  id       String @id @default(uuid())
  userId   String
  walletId String

  direction WalletCashflowDirection
  source    WalletCashflowSource

  amount     Float
  currency   String
  occurredAt DateTime

  exchangeEventId   String?
  balanceSnapshotId String?
  orderId           String?
  tradeId           String?
  positionId        String?
  metadata          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet          Wallet                 @relation(fields: [walletId], references: [id], onDelete: Cascade)
  balanceSnapshot WalletBalanceSnapshot? @relation(fields: [balanceSnapshotId], references: [id], onDelete: SetNull)
  order           Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  trade           Trade?                 @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  position        Position?              @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@unique([walletId, exchangeEventId, source])
  @@index([userId])
  @@index([walletId, occurredAt])
  @@index([userId, walletId, occurredAt])
  @@index([source, occurredAt])
  @@index([direction, occurredAt])
  @@index([balanceSnapshotId])
  @@index([orderId])
  @@index([tradeId])
  @@index([positionId])
}

model Position {
  id             String                 @id @default(uuid())
  userId         String
  botId          String?
  strategyId     String?
  walletId       String?
  externalId     String?
  origin         TradingRecordOrigin    @default(BOT)
  managementMode PositionManagementMode @default(BOT_MANAGED)
  syncState      SyncState              @default(IN_SYNC)
  continuityState PositionContinuityState @default(CONFIRMED)

  symbol        String
  side          PositionSide
  status        PositionStatus @default(OPEN)
  entryPrice    Float
  quantity      Float
  leverage      Int            @default(1)
  closeReason   PositionCloseReason?
  closeInitiator PositionCloseInitiator?
  stopLoss      Float?
  takeProfit    Float?
  openedAt      DateTime       @default(now())
  closedAt      DateTime?
  realizedPnl   Float?
  unrealizedPnl Float?
  marginUsed    Float?
  lastExchangeSeenAt DateTime?
  lastExchangeSyncAt DateTime?
  missingSince       DateTime?
  missingSyncCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  bot        Bot?        @relation(fields: [botId], references: [id])
  strategy   Strategy?   @relation(fields: [strategyId], references: [id])
    wallet     Wallet?     @relation(fields: [walletId], references: [id], onDelete: SetNull)
    orders     Order[]
    trades     Trade[]
    orderFills OrderFill[]
    walletCashflowEvents WalletCashflowEvent[]

  @@index([userId])
  @@index([userId, openedAt])
  @@index([userId, status, openedAt])
  @@index([userId, symbol, openedAt])
  @@index([userId, botId, status])
  @@index([userId, symbol, status])
  @@index([userId, origin, openedAt])
  @@index([userId, managementMode, openedAt])
  @@index([botId])
  @@index([walletId])
  @@index([strategyId])
  @@index([externalId])
  @@index([symbol])
  @@index([status])
}

model Order {
  id             String                 @id @default(uuid())
  userId         String
  botId          String?
  strategyId     String?
  positionId     String?
  walletId       String?
  origin         TradingRecordOrigin    @default(BOT)
  managementMode PositionManagementMode @default(BOT_MANAGED)
  syncState      SyncState              @default(IN_SYNC)

  symbol           String
  side             OrderSide
  type             OrderType
  closeReason      PositionCloseReason?
  closeInitiator   PositionCloseInitiator?
  status           OrderStatus @default(PENDING)
  quantity         Float
  price            Float?
  stopPrice        Float?
  filledQuantity   Float       @default(0)
  averageFillPrice Float?
  fee              Float?
  feeSource        FeeSource   @default(ESTIMATED)
  feePending       Boolean     @default(false)
  feeCurrency      String?
  effectiveFeeRate Float?
  exchangeOrderId  String?
  exchangeTradeId  String?
  submittedAt      DateTime?
  filledAt         DateTime?
  canceledAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id])
  bot      Bot?        @relation(fields: [botId], references: [id])
  strategy Strategy?   @relation(fields: [strategyId], references: [id])
  position Position?   @relation(fields: [positionId], references: [id])
    wallet   Wallet?     @relation(fields: [walletId], references: [id], onDelete: SetNull)
    trades   Trade[]
    fills    OrderFill[]
    walletCashflowEvents WalletCashflowEvent[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, symbol, createdAt])
  @@index([userId, origin, createdAt])
  @@index([userId, managementMode, createdAt])
  @@index([botId])
  @@index([walletId])
  @@index([strategyId])
  @@index([positionId])
  @@index([exchangeOrderId])
  @@index([exchangeTradeId])
  @@index([feeSource, feePending])
  @@index([symbol])
  @@index([status])
}

model Trade {
  id             String                 @id @default(uuid())
  userId         String
  botId          String?
  strategyId     String?
  orderId        String?
  positionId     String?
  walletId       String?
  origin         TradingRecordOrigin    @default(BOT)
  managementMode PositionManagementMode @default(BOT_MANAGED)

  symbol           String
  side             OrderSide
  lifecycleAction  TradeLifecycleAction @default(UNKNOWN)
  closeReason      PositionCloseReason?
  closeInitiator   PositionCloseInitiator?
  price            Float
  quantity         Float
  fee              Float?
  feeSource        FeeSource            @default(ESTIMATED)
  feePending       Boolean              @default(false)
  feeCurrency      String?
  effectiveFeeRate Float?
  exchangeTradeId  String?
  realizedPnl      Float?
  executedAt       DateTime             @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id])
  bot      Bot?        @relation(fields: [botId], references: [id])
  strategy Strategy?   @relation(fields: [strategyId], references: [id])
  order    Order?      @relation(fields: [orderId], references: [id])
  position Position?   @relation(fields: [positionId], references: [id])
    wallet   Wallet?     @relation(fields: [walletId], references: [id], onDelete: SetNull)
    fills    OrderFill[]
    walletCashflowEvents WalletCashflowEvent[]

  @@index([userId])
  @@index([botId])
  @@index([walletId])
  @@index([strategyId])
  @@index([orderId])
  @@index([positionId])
  @@index([userId, origin, executedAt])
  @@index([userId, managementMode, executedAt])
  @@index([exchangeTradeId])
  @@index([feeSource, feePending])
  @@index([symbol])
}

model OrderFill {
  id String @id @default(uuid())

  userId     String
  botId      String?
  strategyId String?
  orderId    String
  tradeId    String?
  positionId String?

  symbol String
  side   OrderSide

  exchangeTradeId String
  price           Float
  quantity        Float
  notional        Float
  feeCost         Float?
  feeCurrency     String?
  feeRate         Float?
  executedAt      DateTime
  raw             Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  bot      Bot?      @relation(fields: [botId], references: [id], onDelete: SetNull)
  strategy Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trade    Trade?    @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([botId])
  @@index([strategyId])
  @@index([orderId])
  @@index([tradeId])
  @@index([positionId])
  @@index([exchangeTradeId])
  @@index([symbol])
  @@index([executedAt])
  @@index([userId, executedAt])
}

model Signal {
  id         String  @id @default(uuid())
  userId     String
  botId      String?
  strategyId String?

  symbol      String
  timeframe   String
  direction   SignalDirection
  confidence  Float?
  payload     Json?
  triggeredAt DateTime        @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  bot      Bot?      @relation(fields: [botId], references: [id])
  strategy Strategy? @relation(fields: [strategyId], references: [id])

  @@index([userId])
  @@index([botId])
  @@index([strategyId])
  @@index([symbol])
  @@index([triggeredAt])
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
}

enum PositionCloseReason {
  TP
  TTP
  SL
  TSL
  LIQUIDATION
  ACCOUNT_FLOOR
  MANUAL
  SIGNAL_EXIT
  POSITION_LIFETIME
  EXTERNAL_SYNC_MISSING
  SYSTEM_REPAIR
}

enum PositionCloseInitiator {
  BOT_APP
  USER_APP
  USER_EXCHANGE
  EXCHANGE
  SYSTEM_REPAIR
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
  STOP_LIMIT
  TAKE_PROFIT
  TRAILING
}

enum OrderStatus {
  PENDING
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELED
  REJECTED
  EXPIRED
}

enum SignalDirection {
  LONG
  SHORT
  EXIT
}

enum TradeLifecycleAction {
  OPEN
  DCA
  CLOSE
  UNKNOWN
}

enum FeeSource {
  ESTIMATED
  EXCHANGE_FILL
}

enum TradingRecordOrigin {
  BOT
  USER
  EXCHANGE_SYNC
  BACKTEST
}

enum PositionManagementMode {
  BOT_MANAGED
  MANUAL_MANAGED
}

enum SyncState {
  IN_SYNC
  DRIFT
  ORPHAN_LOCAL
  ORPHAN_EXCHANGE
}

enum PositionContinuityState {
  CONFIRMED
  RECOVERING
  RECOVERED_UNACTIONABLE
  EXTERNAL_CLOSE_CONFIRMED
  REPAIR_ONLY_CLEANUP
}

model BacktestRun {
  id         String  @id @default(uuid())
  userId     String
  strategyId String?

  name       String
  symbol     String
  timeframe  String
  startedAt  DateTime       @default(now())
  finishedAt DateTime?
  status     BacktestStatus @default(PENDING)
  seedConfig Json?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  strategy Strategy?       @relation(fields: [strategyId], references: [id])
  trades   BacktestTrade[]
  report   BacktestReport?

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([strategyId])
  @@index([status])
  @@index([startedAt])
}

model BacktestTrade {
  id            String  @id @default(uuid())
  userId        String
  strategyId    String?
  backtestRunId String

  symbol     String
  side       PositionSide
  entryPrice Float
  exitPrice  Float
  quantity   Float
  openedAt   DateTime
  closedAt   DateTime
  pnl        Float
  fee        Float?
  exitReason BacktestExitReason @default(SIGNAL_EXIT)
  liquidated Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  strategy    Strategy?   @relation(fields: [strategyId], references: [id])
  backtestRun BacktestRun @relation(fields: [backtestRunId], references: [id])

  @@index([userId])
  @@index([userId, backtestRunId, closedAt])
  @@index([strategyId])
  @@index([backtestRunId])
  @@index([symbol])
}

enum BacktestExitReason {
  SIGNAL_EXIT
  FINAL_CANDLE
  LIQUIDATION
}

model BacktestReport {
  id            String @id @default(uuid())
  userId        String
  backtestRunId String @unique

  totalTrades   Int    @default(0)
  winningTrades Int    @default(0)
  losingTrades  Int    @default(0)
  winRate       Float?
  netPnl        Float?
  grossProfit   Float?
  grossLoss     Float?
  maxDrawdown   Float?
  sharpe        Float?
  metrics       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  backtestRun BacktestRun @relation(fields: [backtestRunId], references: [id])

  @@index([userId])
}

enum BacktestStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

model Log {
  id         String  @id @default(uuid())
  userId     String
  botId      String?
  strategyId String?

  action     String
  level      LogLevel @default(INFO)
  source     String
  message    String
  category   String?
  entityType String?
  entityId   String?
  actor      String?
  ipAddress  String?
  metadata   Json?
  occurredAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  bot      Bot?      @relation(fields: [botId], references: [id])
  strategy Strategy? @relation(fields: [strategyId], references: [id])

  @@index([userId])
  @@index([userId, occurredAt])
  @@index([userId, source, occurredAt])
  @@index([userId, actor, occurredAt])
  @@index([userId, level, occurredAt])
  @@index([botId])
  @@index([strategyId])
  @@index([level])
  @@index([source])
  @@index([occurredAt])
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}
