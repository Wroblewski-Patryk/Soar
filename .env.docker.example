# Soar local Docker app stack template.
# Copy to: .env.docker
#
# This file is safe example material for local containers only. Do not paste
# production secrets or live exchange credentials into this template.

NODE_ENV=production

# Local container-to-container datastore URLs.
POSTGRES_PASSWORD=local-postgres-password
REDIS_PASSWORD=local-redis-password
DATABASE_URL=postgresql://postgres:local-postgres-password@postgres:5432/cryptosparrow?schema=public
REDIS_URL=redis://:local-redis-password@redis:6379

# Public/local service URLs.
SERVER_PORT=3001
SERVER_URL=http://localhost:3001
CLIENT_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Local-only cryptographic material. Rotate these in .env.docker before
# long-lived local usage. Never reuse them in shared/stage/prod environments.
JWT_SECRET=jwtdev_7b29c8f1a6424d93b8e05a7c61f4d2e9a73f06c8
API_KEY_ENCRYPTION_KEYS=v1:apikeydev_4e91b82c0d5a46f79b3016e8c2a07fd5
API_KEY_ENCRYPTION_ACTIVE_VERSION=v1

# Split worker topology mirrors Coolify.
WORKER_MODE=split
WORKER_MARKET_DATA_OWNERSHIP=worker
WORKER_BACKTEST_OWNERSHIP=worker
WORKER_MARKET_DATA_QUEUE=market-data
WORKER_BACKTEST_QUEUE=backtest
WORKER_EXECUTION_QUEUE=execution

# Market/runtime defaults for local Docker parity.
BINANCE_SPOT_REST_URL=https://api.binance.com
BINANCE_FUTURES_REST_URL=https://fapi.binance.com
MARKET_STREAM_MARKET_TYPE=FUTURES
MARKET_STREAM_INTERVALS=5m
MARKET_STREAM_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT
MARKET_STREAM_SUBSCRIPTIONS_REFRESH_MS=10000
RUNTIME_SCAN_INTERVAL_MS=5000
RUNTIME_SCAN_MAX_SYMBOLS=100
RUNTIME_SIGNAL_LOOP_BOOTSTRAP_INTERVAL_MS=10000
