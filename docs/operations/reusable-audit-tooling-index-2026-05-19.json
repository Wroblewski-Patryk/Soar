  "primaryCommand": "corepack pnpm run audit:manifest:verify",
  "tools": [
    {
      "id": "AUDIT-MANIFEST-CHECK",
      "command": "corepack pnpm run audit:manifest:check",
      "script": "scripts/checkReusableAuditManifest.mjs",
      "purpose": "Validate manifest JSON coverage, referenced paths, and open-decision links."
    },
    {
      "id": "AUDIT-MANIFEST-CHECK-TEST",
      "command": "corepack pnpm run audit:manifest:check:test",
      "script": "scripts/checkReusableAuditManifest.test.mjs",
      "purpose": "Regression-test missing audit IDs, duplicate IDs, missing paths, and missing decision links."
    },
    {
      "id": "AUDIT-MANIFEST-COMPARE",
      "command": "corepack pnpm run audit:manifest:compare -- --base <path> --target <path>",
      "script": "scripts/compareReusableAuditManifests.mjs",
      "purpose": "Compare two audit manifests for regressions and improvements."
    },
    {
      "id": "AUDIT-MANIFEST-COMPARE-TEST",
      "command": "corepack pnpm run audit:manifest:compare:test",
      "script": "scripts/compareReusableAuditManifests.test.mjs",
      "purpose": "Regression-test status, summary, decision, and safety-boundary comparison behavior."
    },
    {
      "id": "AUDIT-MANIFEST-VERIFY",
      "command": "corepack pnpm run audit:manifest:verify",
      "script": "package.json",
      "purpose": "Run the complete manifest/playbook verification bundle."
    },
    {
      "id": "AUDIT-RERUN-PLAYBOOK-CHECK",
      "command": "corepack pnpm run audit:rerun-playbook:check",
