# Soar Coolify Service Stack env template.
# Copy values from the existing production resources in Coolify. Do not commit
# filled production secrets.

NODE_ENV=production

# Public domains.
SERVER_URL=https://api.soar.luckysparrow.ch
CLIENT_URL=https://soar.luckysparrow.ch
CORS_ORIGINS=https://soar.luckysparrow.ch
NEXT_PUBLIC_API_BASE_URL=https://api.soar.luckysparrow.ch
SERVICE_FQDN_API_3001=https://api.soar.luckysparrow.ch
SERVICE_FQDN_WEB_3002=https://soar.luckysparrow.ch

# Deployment identity. Set SOURCE_COMMIT to the exact candidate SHA deployed
# by the stack so /api/build-info remains release-gate compatible.
SOURCE_COMMIT=CHANGEME_EXPECTED_GIT_SHA
SOURCE_BRANCH=main
COOLIFY_BRANCH=main

# Existing production data stores. Prefer the already-provisioned Coolify
# Postgres/Redis resources during the stack migration to avoid data movement.
DATABASE_URL=CHANGEME_EXISTING_PRODUCTION_DATABASE_URL
REDIS_URL=CHANGEME_EXISTING_PRODUCTION_REDIS_URL

# Auth/session/secret material copied from current production resources.
JWT_SECRET=CHANGEME_EXISTING_PRODUCTION_JWT_SECRET
COOKIE_DOMAIN=.luckysparrow.ch
COOKIE_SAME_SITE=lax
API_KEY_ENCRYPTION_KEYS=CHANGEME_EXISTING_VERSIONED_KEYRING
API_KEY_ENCRYPTION_ACTIVE_VERSION=v1

# Split worker topology.
WORKER_MODE=split
WORKER_MARKET_DATA_OWNERSHIP=worker
WORKER_BACKTEST_OWNERSHIP=worker
WORKER_MARKET_DATA_QUEUE=market-data
WORKER_BACKTEST_QUEUE=backtest
WORKER_EXECUTION_QUEUE=execution

# Runtime and market-data defaults. Override only with intentional production
# values from the existing Coolify applications.
BINANCE_SPOT_REST_URL=https://api.binance.com
BINANCE_FUTURES_REST_URL=https://fapi.binance.com
MARKET_STREAM_MARKET_TYPE=FUTURES
MARKET_STREAM_INTERVALS=5m
MARKET_STREAM_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT
MARKET_STREAM_SUBSCRIPTIONS_REFRESH_MS=10000
RUNTIME_SCAN_INTERVAL_MS=5000
RUNTIME_SCAN_MAX_SYMBOLS=100
RUNTIME_SIGNAL_LOOP_BOOTSTRAP_INTERVAL_MS=10000

# Memory guardrails for VPS stability. Raise only after SLO evidence says it is
# needed and the host has enough headroom.
API_NODE_OPTIONS=--max-old-space-size=768
WEB_NODE_OPTIONS=--max-old-space-size=512
WORKER_NODE_OPTIONS=--max-old-space-size=384
MARKET_STREAM_NODE_OPTIONS=--experimental-websocket --max-old-space-size=384

# Optional paid/traffic-control integrations.
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
COIN_ICON_CACHE_TTL_MINUTES=360
